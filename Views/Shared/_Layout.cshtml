<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MEU RENT</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400&family=Rubik+Glitch&family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "bg-app": "#0D0D0D",
                        "surface": "#1A1A1A",
                        "surface-raised": "#242424",
                        "border": "#2E2E2E",
                        "primary": "#FFFFFF",
                        "orange-light": "#E5E5E5",
                        "text-primary": "#F2F2F2",
                        "text-secondary": "#8A8A8A",
                        "text-muted": "#5A5A5A",
                        "success": "#22C55E",
                        "warning": "#F59E0B",
                        "info": "#60A5FA",
                        "error": "#EF4444"
                    },
                    borderRadius: {
                        DEFAULT: "0.125rem",
                        lg: "0.25rem",
                        xl: "0.5rem",
                        full: "0.75rem"
                    },
                    spacing: {
                        gutter: "24px",
                        "gap-xs": "8px",
                        "gap-sm": "16px",
                        "gap-md": "24px",
                        "gap-lg": "32px",
                        "section-sm": "48px",
                        "section-md": "64px",
                        "section-lg": "96px",
                        "container-max": "1200px"
                    },
                    fontFamily: {
                        body: ["Inter", "system-ui", "sans-serif"],
                        display: ["Inter", "system-ui", "sans-serif"],
                        code: ["JetBrains Mono", "monospace"],
                        serif: ["Rubik Glitch", "sans-serif"]
                    },
                    fontSize: {
                        body: ["17px", { lineHeight: "1.65", letterSpacing: "0", fontWeight: "400" }],
                        caption: ["14px", { lineHeight: "1.5", letterSpacing: "0", fontWeight: "400" }],
                        h3: ["22px", { lineHeight: "1.3", letterSpacing: "0", fontWeight: "600" }],
                        h2: ["32px", { lineHeight: "1.2", letterSpacing: "0", fontWeight: "700" }],
                        h1: ["44px", { lineHeight: "1.1", letterSpacing: "0", fontWeight: "700" }],
                        display: ["60px", { lineHeight: "1.05", letterSpacing: "0", fontWeight: "800" }]
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-bg-app text-text-primary font-body antialiased min-h-screen flex flex-col @ViewData["BodyClass"]">
    <header class="frosted-nav fixed top-0 w-full h-16 z-50">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center px-gutter max-w-container-max mx-auto h-full">
            <nav class="hidden md:flex gap-gap-md">
                <a class="text-white hover:text-primary transition-colors duration-200 font-semibold" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                <a class="text-white hover:text-primary transition-colors duration-200 font-semibold" asp-controller="Cars" asp-action="Index">Araçlar</a>
            </nav>
            <a class="text-h2 font-black text-white" style="font-family: 'Gelasio', serif;" asp-controller="Home" asp-action="Index">MEU RENT</a>
            <div class="flex items-center gap-gap-sm justify-end">
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <div class="relative">
                        <button class="flex items-center gap-1 text-white hover:text-primary transition-colors duration-200 font-semibold bg-transparent border-0 cursor-pointer" onclick="var m=document.getElementById('userMenu'); m.style.display=m.style.display==='flex'?'none':'flex'">
                            <span class="material-symbols-outlined">menu</span>
                        </button>
                        <div id="userMenu" class="absolute right-0 top-full mt-2 w-48 orion-card p-gap-xs hidden flex-col gap-gap-xs" style="display:none">
                            <span class="text-caption text-text-secondary px-2 pt-1">@Context.Session.GetString("UserEmail")</span>
                            <hr class="border-border" />
                            <a class="text-white hover:text-primary transition-colors duration-200 font-semibold px-2 py-1 rounded hover:bg-surface-raised" asp-controller="Admin" asp-action="Index">Admin Panel</a>
                            <a class="text-white hover:text-primary transition-colors duration-200 font-semibold px-2 py-1 rounded hover:bg-surface-raised" asp-controller="Home" asp-action="About">Hakkımızda</a>
                            <hr class="border-border" />
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button class="w-full text-left text-white hover:text-primary transition-colors duration-200 bg-transparent border-0 cursor-pointer font-semibold px-2 py-1 rounded hover:bg-surface-raised" type="submit">Çıkış</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a class="hidden md:flex text-white hover:text-primary transition-colors duration-200 font-semibold" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                    <a class="text-white hover:text-primary transition-colors duration-200 font-semibold" asp-controller="Home" asp-action="About">Hakkımızda</a>
                }
            </div>
        </div>
    </header>

    <main class="flex-grow pt-16">
        @RenderBody()
    </main>

    <footer class="border-t border-border bg-bg-app">
        <div class="max-w-container-max mx-auto px-gutter py-gap-lg flex flex-col md:flex-row justify-between gap-gap-sm text-text-secondary text-caption">
            <span>&copy; @DateTime.Now.Year MEU RENT</span>
            <span>Hızlı rezervasyon için modern araç kiralama deneyimi.</span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener('click', function(e) {
            var menu = document.getElementById('userMenu');
            if (menu && !e.target.closest('#userMenu') && !e.target.closest('button[onclick*="userMenu"]')) {
                menu.style.display = 'none';
            }
        });
    </script>
</body>
</html>
