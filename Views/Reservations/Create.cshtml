@model RentACarService.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Rezervasyon Oluştur";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="mb-gap-lg">
        <span class="text-primary font-bold uppercase tracking-wide text-caption">Rezervasyon</span>
        <h1 class="text-h1 font-bold text-text-primary mt-2">Rezervasyonu Onayla</h1>
        <p class="text-text-secondary max-w-2xl">Seçilen aracı inceleyin, müşteri bilgilerini girin ve kiralama talebini onaylayın.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="mb-gap-md bg-success/10 border border-success text-success p-gap-sm rounded" role="alert">
            @successMessage
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-gap-lg items-start">
        <form class="orion-card p-gap-md" asp-controller="Reservations" asp-action="Create" method="post">
            <input asp-for="SelectedCarId" type="hidden" />
            <input asp-for="RentalDays" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-error mb-gap-sm"></div>

            <div class="mb-gap-md">
                <h2 class="text-h3 font-semibold mb-gap-sm">Müşteri Bilgileri</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gap-sm">
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="FullName">Ad soyad</label>
                        <input class="orion-input" asp-for="FullName" placeholder="Ad soyad girin" />
                        <span class="text-error text-caption" asp-validation-for="FullName"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="Email">E-posta</label>
                        <input class="orion-input" asp-for="Email" placeholder="ad@ornek.com" />
                        <span class="text-error text-caption" asp-validation-for="Email"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PhoneNumber">Telefon numarası</label>
                        <input class="orion-input" asp-for="PhoneNumber" placeholder="+90 555 000 00 00" />
                        <span class="text-error text-caption" asp-validation-for="PhoneNumber"></span>
                    </div>
                </div>
            </div>

            <div>
                <h2 class="text-h3 font-semibold mb-gap-sm">Rezervasyon Detayları</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gap-sm">
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PickupDate">Alış tarihi</label>
                        <input class="orion-input" asp-for="PickupDate" />
                        <span class="text-error text-caption" asp-validation-for="PickupDate"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="ReturnDate">İade tarihi</label>
                        <input class="orion-input" asp-for="ReturnDate" />
                        <span class="text-error text-caption" asp-validation-for="ReturnDate"></span>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PickupLocation">Alış lokasyonu</label>
                        <input class="orion-input" asp-for="PickupLocation" placeholder="Kiralama ofisi veya şehir" />
                        <span class="text-error text-caption" asp-validation-for="PickupLocation"></span>
                    </div>
                </div>
            </div>

            <button class="orion-button orion-button-primary mt-gap-md w-full md:w-auto" type="submit">
                Rezervasyonu Onayla
                <span class="material-symbols-outlined">check_circle</span>
            </button>
        </form>

        <aside class="flex flex-col gap-gap-md">
            <div class="orion-card overflow-hidden">
                <img alt="@Model.SelectedCar.Brand @Model.SelectedCar.Model" class="w-full h-56 object-cover" src="/images/cars/porsche-911-turbo-s-1.jpg" />
                <div class="p-gap-sm">
                    <p class="text-text-secondary text-caption">Seçilen araç</p>
                    <h2 class="text-h3 font-semibold">@Model.SelectedCar.Brand @Model.SelectedCar.Model</h2>
                    <p class="text-text-secondary">@Model.SelectedCar.Transmission, @Model.SelectedCar.FuelType, @Model.SelectedCar.Year</p>
                </div>
            </div>

            <div class="orion-card p-gap-md">
                <h2 class="text-h3 font-semibold mb-gap-sm">Fiyat Özeti</h2>
                <div class="flex justify-between text-text-secondary mb-gap-xs">
                    <span>Günlük fiyat</span>
                    <strong class="text-text-primary">$@Model.SelectedCar.DailyPrice</strong>
                </div>
                <div class="flex justify-between text-text-secondary mb-gap-sm">
                    <span>Kiralama günü</span>
                    <strong class="text-text-primary">@Model.RentalDays</strong>
                </div>
                <div class="border-t border-border pt-gap-sm flex justify-between items-center">
                    <span class="text-text-primary font-semibold">Toplam</span>
                    <strong class="font-code text-primary text-h2">$@Model.TotalPrice</strong>
                </div>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
