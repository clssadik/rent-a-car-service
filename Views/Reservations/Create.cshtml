@model RentACarService.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<section class="page-section">
    <div class="container">
        <div class="page-title-row">
            <div>
                <span class="section-label">Reservation form</span>
                <h1>Create Reservation</h1>
            </div>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="alert">
                @successMessage
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <form class="form-panel" asp-controller="Reservations" asp-action="Create" method="post">
                    <input asp-for="SelectedCarId" type="hidden" />
                    <input asp-for="RentalDays" type="hidden" />

                    <h5>Customer Information</h5>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="FullName">Full name</label>
                            <input class="form-control" asp-for="FullName" placeholder="Enter full name" />
                            <span class="text-danger small" asp-validation-for="FullName"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Email">Email</label>
                            <input class="form-control" asp-for="Email" placeholder="name@example.com" />
                            <span class="text-danger small" asp-validation-for="Email"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="PhoneNumber">Phone number</label>
                            <input class="form-control" asp-for="PhoneNumber" placeholder="+90 555 000 00 00" />
                            <span class="text-danger small" asp-validation-for="PhoneNumber"></span>
                        </div>
                    </div>

                    <h5>Reservation Details</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="PickupDate">Pickup date</label>
                            <input class="form-control" asp-for="PickupDate" />
                            <span class="text-danger small" asp-validation-for="PickupDate"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="ReturnDate">Return date</label>
                            <input class="form-control" asp-for="ReturnDate" />
                            <span class="text-danger small" asp-validation-for="ReturnDate"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="PickupLocation">Pickup location</label>
                            <input class="form-control" asp-for="PickupLocation" placeholder="Rental office or city" />
                            <span class="text-danger small" asp-validation-for="PickupLocation"></span>
                        </div>
                    </div>

                    <button class="btn btn-primary mt-4" type="submit">Confirm Reservation</button>
                </form>
            </div>
            <div class="col-lg-4">
                <div class="summary-card mb-4">
                    <h5>Selected Car</h5>
                    <div class="car-image-placeholder small-placeholder">Car Image</div>
                    <h6 class="mt-3 mb-1">@Model.SelectedCar.Brand @Model.SelectedCar.Model</h6>
                    <p class="text-muted mb-0">@Model.SelectedCar.Transmission, @Model.SelectedCar.FuelType, @Model.SelectedCar.Year</p>
                </div>

                <div class="summary-card">
                    <h5>Total Price</h5>
                    <div class="summary-line">
                        <span>Daily price</span>
                        <strong>$@Model.SelectedCar.DailyPrice</strong>
                    </div>
                    <div class="summary-line">
                        <span>Rental days</span>
                        <strong>@Model.RentalDays</strong>
                    </div>
                    <hr />
                    <div class="summary-line total">
                        <span>Total</span>
                        <strong>$@Model.TotalPrice</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
