@model RentACarService.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Create Reservation";
    var carImage = "https://lh3.googleusercontent.com/aida-public/AB6AXuA6h3uOi4kCTSpHFkJZ6-r4DXwuWzU_EImY_NOpLZ2DoiFfe_Qg0uoikWaZdXx3wna4mhnNHfrHI_LhxMG4Wg_fP5HCU1jAyUPPCyUUN_Ef2-Iir4WBSdr0pSDVhFJTt3mltGKfWwCm06lkaGwJ27f7fAKhc3QhAjGwiF__4suSCSojQXB_m7YIuqhYV0jJ2B0zW67IerCLYW8NBiBS6e4cDq5hm7pt4J2uh62dgQqsv6TjYgavXPx1bCxW1OBkJjYMOCYf8yhHzI";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="mb-gap-lg">
        <span class="text-primary font-bold uppercase tracking-wide text-caption">Reservation</span>
        <h1 class="text-h1 font-bold text-text-primary mt-2">Confirm Reservation</h1>
        <p class="text-text-secondary max-w-2xl">Review the selected car, enter customer details and confirm the rental request.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="mb-gap-md bg-success/10 border border-success text-success p-gap-sm rounded" role="alert">
            @successMessage
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-gap-lg items-start">
        <form class="orion-card p-gap-md" asp-controller="Reservations" asp-action="Create" method="post">
            <input asp-for="SelectedCarId" type="hidden" />
            <input asp-for="RentalDays" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-error mb-gap-sm"></div>

            <div class="mb-gap-md">
                <h2 class="text-h3 font-semibold mb-gap-sm">Customer Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gap-sm">
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="FullName">Full name</label>
                        <input class="orion-input" asp-for="FullName" placeholder="Enter full name" />
                        <span class="text-error text-caption" asp-validation-for="FullName"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="Email">Email</label>
                        <input class="orion-input" asp-for="Email" placeholder="name@example.com" />
                        <span class="text-error text-caption" asp-validation-for="Email"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PhoneNumber">Phone number</label>
                        <input class="orion-input" asp-for="PhoneNumber" placeholder="+90 555 000 00 00" />
                        <span class="text-error text-caption" asp-validation-for="PhoneNumber"></span>
                    </div>
                </div>
            </div>

            <div>
                <h2 class="text-h3 font-semibold mb-gap-sm">Reservation Details</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gap-sm">
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PickupDate">Pickup date</label>
                        <input class="orion-input" asp-for="PickupDate" />
                        <span class="text-error text-caption" asp-validation-for="PickupDate"></span>
                    </div>
                    <div>
                        <label class="block text-caption text-text-secondary mb-2" asp-for="ReturnDate">Return date</label>
                        <input class="orion-input" asp-for="ReturnDate" />
                        <span class="text-error text-caption" asp-validation-for="ReturnDate"></span>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-caption text-text-secondary mb-2" asp-for="PickupLocation">Pickup location</label>
                        <input class="orion-input" asp-for="PickupLocation" placeholder="Rental office or city" />
                        <span class="text-error text-caption" asp-validation-for="PickupLocation"></span>
                    </div>
                </div>
            </div>

            <button class="orion-button orion-button-primary mt-gap-md w-full md:w-auto" type="submit">
                Confirm Reservation
                <span class="material-symbols-outlined">check_circle</span>
            </button>
        </form>

        <aside class="flex flex-col gap-gap-md">
            <div class="orion-card overflow-hidden">
                <img alt="@Model.SelectedCar.Brand @Model.SelectedCar.Model" class="w-full h-56 object-cover" src="@carImage" />
                <div class="p-gap-sm">
                    <p class="text-text-secondary text-caption">Selected car</p>
                    <h2 class="text-h3 font-semibold">@Model.SelectedCar.Brand @Model.SelectedCar.Model</h2>
                    <p class="text-text-secondary">@Model.SelectedCar.Transmission, @Model.SelectedCar.FuelType, @Model.SelectedCar.Year</p>
                </div>
            </div>

            <div class="orion-card p-gap-md">
                <h2 class="text-h3 font-semibold mb-gap-sm">Price Summary</h2>
                <div class="flex justify-between text-text-secondary mb-gap-xs">
                    <span>Daily price</span>
                    <strong class="text-text-primary">$@Model.SelectedCar.DailyPrice</strong>
                </div>
                <div class="flex justify-between text-text-secondary mb-gap-sm">
                    <span>Rental days</span>
                    <strong class="text-text-primary">@Model.RentalDays</strong>
                </div>
                <div class="border-t border-border pt-gap-sm flex justify-between items-center">
                    <span class="text-text-primary font-semibold">Total</span>
                    <strong class="font-code text-primary text-h2">$@Model.TotalPrice</strong>
                </div>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
