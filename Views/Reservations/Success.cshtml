@model RentACarService.ViewModels.ReservationSuccessViewModel

@{
    ViewData["Title"] = "Rezervasyon Onaylandı";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="max-w-2xl mx-auto text-center mb-gap-lg">
        <span class="material-symbols-outlined text-success text-6xl">check_circle</span>
        <h1 class="text-h1 font-bold text-text-primary mt-gap-sm">Rezervasyon Onaylandı</h1>
        <p class="text-text-secondary mt-2">Rezervasyonunuz başarıyla oluşturuldu. Kısa süre içinde e-posta onayı gönderilecektir.</p>
    </div>

    <div class="orion-card p-gap-md max-w-2xl mx-auto">
        <h2 class="text-h3 font-semibold mb-gap-sm">Rezervasyon Detayları</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-gap-sm">
            <div>
                <p class="text-caption text-text-secondary">Rezervasyon No</p>
                <p class="font-code text-text-primary font-semibold">#@Model.ReservationId</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Durum</p>
                <span class="inline-block bg-success/10 text-success text-caption px-2 py-1 rounded font-bold">@Model.Status</span>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Müşteri Adı</p>
                <p class="text-text-primary">@Model.CustomerName</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">E-posta</p>
                <p class="text-text-primary">@Model.CustomerEmail</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Araç</p>
                <p class="text-text-primary font-semibold">@Model.CarBrand @Model.CarModel</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Alış Lokasyonu</p>
                <p class="text-text-primary">@Model.PickupLocation</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Alış Tarihi</p>
                <p class="text-text-primary">@Model.PickupDate.ToString("MMM dd, yyyy")</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">İade Tarihi</p>
                <p class="text-text-primary">@Model.ReturnDate.ToString("MMM dd, yyyy")</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Kiralama Günü</p>
                <p class="text-text-primary">@Model.RentalDays gün</p>
            </div>
            <div>
                <p class="text-caption text-text-secondary">Toplam Fiyat</p>
                <p class="font-code text-primary text-h2 font-bold">$@Model.TotalPrice</p>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-gap-sm mt-gap-md pt-gap-md border-t border-border">
            <a class="orion-button orion-button-outline flex-1 text-center" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined">home</span>
                Ana Sayfaya Dön
            </a>
            <a class="orion-button orion-button-primary flex-1 text-center" asp-controller="Reservations" asp-action="Create">
                <span class="material-symbols-outlined">add_circle</span>
                Yeni Rezervasyon
            </a>
        </div>
    </div>
</section>
