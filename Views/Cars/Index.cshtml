@model RentACarService.ViewModels.CarsIndexViewModel
@using System.IO
@{
    ViewData["Title"] = "Mevcut Araçlar";
    string GetCarImage(RentACarService.Models.Car car)
    {
        var prefix = $"{car.Brand}-{car.Model}".ToLower().Replace(" ", "-");
        var dir = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "cars", prefix);
        if (System.IO.Directory.Exists(dir))
        {
            var first = System.IO.Directory.GetFiles(dir, "*").Select(System.IO.Path.GetFileName).OrderBy(f => f).FirstOrDefault();
            if (first != null) return $"/images/cars/{prefix}/{first}";
        }
        return "/images/cars/porsche-911-turbo-s/porsche-911-turbo-s-1.jpg";
    }
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col gap-gap-xs mb-gap-lg">
        <span class="text-primary font-bold uppercase tracking-wide text-caption">Filoyu İncele</span>
        <h1 class="text-h1 font-bold text-text-primary">Mevcut Araçlar</h1>
        <p class="text-text-secondary max-w-2xl">Marka, tip, vites ve günlük bütçeye göre filtreleyin.</p>
    </div>

    <div class="orion-card p-gap-md mb-gap-lg">
        <form class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-gap-sm" asp-controller="Cars" asp-action="Index" method="get">
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="brand">Marka</label>
                <input class="orion-input" id="brand" name="brand" placeholder="Toyota" type="text" value="@Model.Brand" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="type">Araç tipi</label>
                <select class="orion-input" id="type" name="type">
                    <option value="">Tüm tipler</option>
                    <option value="Sedan" selected="@(Model.Type == "Sedan" ? "selected" : null)">Sedan</option>
                    <option value="SUV" selected="@(Model.Type == "SUV" ? "selected" : null)">SUV</option>
                    <option value="Hatchback" selected="@(Model.Type == "Hatchback" ? "selected" : null)">Hatchback</option>
                    <option value="Van" selected="@(Model.Type == "Van" ? "selected" : null)">Van</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="transmission">Vites</label>
                <select class="orion-input" id="transmission" name="transmission">
                    <option value="">Tümü</option>
                    <option value="Automatic" selected="@(Model.Transmission == "Automatic" ? "selected" : null)">Automatic</option>
                    <option value="Manual" selected="@(Model.Transmission == "Manual" ? "selected" : null)">Manual</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="priceRange">Fiyat aralığı</label>
                <select class="orion-input" id="priceRange" name="priceRange">
                    <option value="">Tüm fiyatlar</option>
                    <option value="0-50" selected="@(Model.PriceRange == "0-50" ? "selected" : null)">$0 - $50</option>
                    <option value="50-80" selected="@(Model.PriceRange == "50-80" ? "selected" : null)">$50 - $80</option>
                    <option value="80+" selected="@(Model.PriceRange == "80+" ? "selected" : null)">$80+</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="orion-button orion-button-primary w-full" type="submit">
                    <span class="material-symbols-outlined">tune</span>
                    Filtrele
                </button>
            </div>
        </form>
    </div>

    @if (Model.Cars.Count == 0)
    {
        <div class="orion-card p-gap-md text-text-secondary">
            Seçilen filtrelere uygun araç bulunamadı.
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gap-md">
        @for (var i = 0; i < Model.Cars.Count; i++)
        {
            var car = Model.Cars[i];
            <article class="orion-card overflow-hidden flex flex-col group hover:border-primary transition-colors">
                <div class="h-56 bg-surface-raised relative overflow-hidden">
                    <img alt="@car.Brand @car.Model" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@GetCarImage(car)" />
                    <div class="absolute top-3 right-3 @(car.IsAvailable ? "bg-success" : "bg-text-muted") text-bg-app text-caption px-2 py-1 rounded font-bold">
                        @(car.IsAvailable ? "MÜSAİT" : "MÜSAİT DEĞİL")
                    </div>
                </div>
                <div class="p-gap-sm flex flex-col gap-gap-sm flex-grow">
                    <div class="flex justify-between items-start gap-gap-sm">
                        <div>
                            <h2 class="text-h3 font-semibold text-text-primary">@car.Brand @car.Model</h2>
                            <p class="text-text-secondary">@car.Type</p>
                        </div>
                        <span class="font-code text-primary font-bold whitespace-nowrap">$@car.DailyPrice/d</span>
                    </div>
                    <div class="grid grid-cols-2 gap-2 text-caption text-text-muted">
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">calendar_month</span>@car.Year</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">settings</span>@car.Transmission</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">local_gas_station</span>@car.FuelType</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">airline_seat_recline_normal</span>@car.SeatCount Koltuk</div>
                    </div>
                    <a class="orion-button orion-button-outline w-full mt-auto" asp-controller="Cars" asp-action="Review" asp-route-id="@car.Id">İncele</a>
                </div>
            </article>
        }
        </div>
    }
</section>
