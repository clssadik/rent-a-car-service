<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col gap-gap-xs mb-gap-lg">
        <span class="text-primary font-bold uppercase tracking-wide text-caption">Browse Fleet</span>
        <h1 class="text-h1 font-bold text-text-primary">Available Cars</h1>
        <p class="text-text-secondary max-w-2xl">Filter premium vehicles by brand, type, transmission and daily budget.</p>
    </div>

    <div class="orion-card p-gap-md mb-gap-lg">
        <form class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-gap-sm">
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="brand">Brand</label>
                <input class="orion-input" id="brand" name="brand" placeholder="Toyota" type="text" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="type">Car type</label>
                <select class="orion-input" id="type" name="type">
                    <option>All types</option>
                    <option>Sedan</option>
                    <option>SUV</option>
                    <option>Hatchback</option>
                    <option>Van</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="transmission">Transmission</label>
                <select class="orion-input" id="transmission" name="transmission">
                    <option>Any</option>
                    <option>Automatic</option>
                    <option>Manual</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="priceRange">Price range</label>
                <select class="orion-input" id="priceRange" name="priceRange">
                    <option>Any price</option>
                    <option>$0 - $50</option>
                    <option>$50 - $80</option>
                    <option>$80+</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="orion-button orion-button-primary w-full" type="submit">
                    <span class="material-symbols-outlined">tune</span>
                    Filter
                </button>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gap-md">
        @for (var i = 0; i < Model.Count; i++)
        {
            var car = Model[i];
            var image = carImages[i % carImages.Length];
            <article class="orion-card overflow-hidden flex flex-col group hover:border-primary transition-colors">
                <div class="h-56 bg-surface-raised relative overflow-hidden">
                    <img alt="@car.Brand @car.Model" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@image" />
                    <div class="absolute top-3 right-3 @(car.IsAvailable ? "bg-success" : "bg-text-muted") text-bg-app text-caption px-2 py-1 rounded font-bold">
                        @(car.IsAvailable ? "AVAILABLE" : "UNAVAILABLE")
                    </div>
                </div>
                <div class="p-gap-sm flex flex-col gap-gap-sm flex-grow">
                    <div class="flex justify-between items-start gap-gap-sm">
                        <div>
                            <h2 class="text-h3 font-semibold text-text-primary">@car.Brand @car.Model</h2>
                            <p class="text-text-secondary">@car.Type</p>
                        </div>
                        <span class="font-code text-primary font-bold whitespace-nowrap">$@car.DailyPrice/d</span>
                    </div>
                    <div class="grid grid-cols-2 gap-2 text-caption text-text-muted">
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">calendar_month</span>@car.Year</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">settings</span>@car.Transmission</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">local_gas_station</span>@car.FuelType</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">airline_seat_recline_normal</span>@car.SeatCount Seats</div>
                    </div>
                    <a class="orion-button orion-button-outline w-full mt-auto" asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">View Details</a>
                </div>
            </article>
        }
    </div>
</section>
