@model RentACarService.Models.Car

@{
    ViewData["Title"] = "Araç Detayları";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-gap-lg items-start">
        <div class="flex flex-col gap-gap-md">
            <div class="orion-card overflow-hidden">
                <img alt="@Model.Brand @Model.Model" class="w-full h-[520px] object-cover" src="/images/cars/porsche-911-turbo-s-1.jpg" />
            </div>
            <div class="grid grid-cols-3 gap-gap-sm">
                <div class="h-28 bg-surface-raised border border-border rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-2.jpg" /></div>
                <div class="h-28 bg-surface-raised border border-border rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-3.jpg" /></div>
                <div class="h-28 bg-surface-raised border border-border rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-4.jpg" /></div>
                <div class="h-28 bg-surface-raised border border-border rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-5.jpg" /></div>
                <div class="h-28 bg-surface-raised border border-border rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-6.jpg" /></div>
                <div class="h-28 bg-surface-raised border border-primary rounded overflow-hidden"><img alt="Porsche 911 Turbo S" class="w-full h-full object-cover" src="/images/cars/porsche-911-turbo-s-1.jpg" /></div>
            </div>
        </div>
        </div>

        <div class="flex flex-col gap-gap-md">
            <div>
                <div class="flex items-center gap-gap-sm mb-gap-sm">
                    <span class="@(Model.IsAvailable ? "bg-success text-bg-app" : "bg-text-muted text-bg-app") text-caption px-2 py-1 rounded font-bold">
                        @(Model.IsAvailable ? "ŞİMDİ MÜSAİT" : "MÜSAİT DEĞİL")
                    </span>
                    <span class="text-text-secondary">@Model.Type</span>
                </div>
                <h1 class="text-display font-extrabold text-text-primary">@Model.Brand @Model.Model</h1>
                <p class="text-text-secondary mt-gap-sm max-w-xl">@Model.Description</p>
            </div>

            <div class="orion-card p-gap-md flex items-center justify-between">
                <div>
                    <p class="text-text-secondary text-caption">Günlük kiralama fiyatı</p>
                    <p class="font-code text-primary text-h1 font-bold">₺@Model.DailyPrice.ToString("N0")</p>
                </div>
                <a class="orion-button orion-button-primary" asp-controller="Reservations" asp-action="Create" asp-route-carId="@Model.Id">
                    Bu Aracı Kirala
                    <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-gap-sm">
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">calendar_month</span>
                    <p class="text-text-secondary text-caption">Yıl</p>
                    <strong>@Model.Year</strong>
                </div>
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">local_gas_station</span>
                    <p class="text-text-secondary text-caption">Yakıt tipi</p>
                    <strong>@Model.FuelType</strong>
                </div>
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">settings</span>
                    <p class="text-text-secondary text-caption">Vites</p>
                    <strong>@Model.Transmission</strong>
                </div>
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">airline_seat_recline_normal</span>
                    <p class="text-text-secondary text-caption">Koltuk sayısı</p>
                    <strong>@Model.SeatCount</strong>
                </div>
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">speed</span>
                    <p class="text-text-secondary text-caption">Kilometre</p>
                    <strong>24,000 km</strong>
                </div>
                <div class="orion-card p-gap-sm">
                    <span class="material-symbols-outlined text-primary mb-2">verified</span>
                    <p class="text-text-secondary text-caption">Durum</p>
                    <strong>@(Model.IsAvailable ? "Hazır" : "Rezerve")</strong>
                </div>
            </div>
        </div>
    </div>
</section>
