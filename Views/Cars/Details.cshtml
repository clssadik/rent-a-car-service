@model RentACarService.Models.Car

@{
    ViewData["Title"] = "Car Details";
}

<section class="page-section">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-6">
                <div class="detail-image-placeholder">Car Image</div>
            </div>
            <div class="col-lg-6">
                <div class="detail-panel">
                    <span class="badge @(Model.IsAvailable ? "text-bg-success" : "text-bg-secondary") mb-3">
                        @(Model.IsAvailable ? "Available" : "Unavailable")
                    </span>
                    <h1>@Model.Brand @Model.Model</h1>
                    <p class="price-text fs-4 mb-4">$@Model.DailyPrice/day</p>

                    <h5>Car Specifications</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="spec-box">
                                <span>Year</span>
                                <strong>@Model.Year</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="spec-box">
                                <span>Fuel type</span>
                                <strong>@Model.FuelType</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="spec-box">
                                <span>Transmission</span>
                                <strong>@Model.Transmission</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="spec-box">
                                <span>Seat count</span>
                                <strong>@Model.SeatCount</strong>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="spec-box">
                                <span>Car type</span>
                                <strong>@Model.Type</strong>
                            </div>
                        </div>
                    </div>

                    <h5>Description</h5>
                    <p class="text-muted">@Model.Description</p>

                    <a class="btn btn-primary btn-lg mt-2" asp-controller="Reservations" asp-action="Create" asp-route-carId="@Model.Id">Rent This Car</a>
                </div>
            </div>
        </div>
    </div>
</section>
