@model RentACarService.ViewModels.AdminReservationsViewModel

@{
    ViewData["Title"] = "Rezervasyon Yönetimi";
}

@{
    string StatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-warning/15 text-warning border border-warning/30",
        "Confirmed" => "bg-primary/15 text-primary border border-primary/30",
        "Completed" => "bg-info/15 text-info border border-info/30",
        "Cancelled" => "bg-error/15 text-error border border-error/30",
        _ => "bg-text-muted/15 text-text-muted border border-text-muted/30"
    };

    string StatusDisplay(string status) => status switch
    {
        "Pending" => "Beklemede",
        "Confirmed" => "Onaylandı",
        "Completed" => "Tamamlandı",
        "Cancelled" => "İptal Edildi",
        _ => status
    };
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-gap-md mb-gap-lg">
        <div>
            <span class="text-primary font-bold uppercase tracking-wide text-caption">Rezervasyon Kontrolü</span>
            <h1 class="text-h1 font-bold text-text-primary mt-2">Rezervasyon Yönetimi</h1>
            <p class="text-text-secondary max-w-2xl">Tüm müşteri rezervasyonlarını görüntüleyin ve yönetin.</p>
        </div>
        <a class="orion-button orion-button-outline" asp-controller="Admin" asp-action="Index">
            <span class="material-symbols-outlined">arrow_back</span>
            Admin Paneli
        </a>
    </div>

    <div class="grid grid-cols-2 gap-gap-md mb-gap-lg">
        <div class="orion-card p-gap-md flex justify-between items-center">
            <span class="text-text-secondary">Toplam Rezervasyon</span>
            <strong class="text-h2 font-bold">@Model.Reservations.Count</strong>
        </div>
        <div class="orion-card p-gap-md flex justify-between items-center">
            <span class="text-text-secondary">Toplam Gelir</span>
            <strong class="text-h2 font-bold text-primary">₺@Model.TotalRevenue.ToString("N0")</strong>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="mb-gap-md bg-success/10 border border-success text-success p-gap-sm rounded" role="alert">
            @successMessage
        </div>
    }

    <div class="orion-card overflow-hidden">
        <div class="p-gap-md border-b border-border flex justify-between items-center">
            <h2 class="text-h3 font-semibold">Tüm Rezervasyonlar</h2>
            <span class="text-text-secondary text-caption">@Model.Reservations.Count kayıt</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-raised text-text-secondary text-caption uppercase">
                    <tr>
                        <th class="px-gap-sm py-gap-sm">ID</th>
                        <th class="px-gap-sm py-gap-sm">Müşteri</th>
                        <th class="px-gap-sm py-gap-sm">Araç</th>
                        <th class="px-gap-sm py-gap-sm">Alış Tarihi</th>
                        <th class="px-gap-sm py-gap-sm">İade Tarihi</th>
                        <th class="px-gap-sm py-gap-sm">Lokasyon</th>
                        <th class="px-gap-sm py-gap-sm">Toplam Fiyat</th>
                        <th class="px-gap-sm py-gap-sm">Durum</th>
                        <th class="px-gap-sm py-gap-sm">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var reservation in Model.Reservations)
                    {
                        <tr class="hover:bg-surface-raised/60 transition-colors">
                            <td class="px-gap-sm py-gap-sm font-code">#@reservation.Id</td>
                            <td class="px-gap-sm py-gap-sm">@reservation.CustomerName</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@reservation.CarName</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@reservation.PickupDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@reservation.ReturnDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@reservation.PickupLocation</td>
                            <td class="px-gap-sm py-gap-sm font-code text-primary">₺@reservation.TotalPrice.ToString("N0")</td>
                            <td class="px-gap-sm py-gap-sm">
                                <span class="inline-block rounded px-2 py-1 text-caption font-semibold @StatusBadgeClass(reservation.Status)">
                                    @StatusDisplay(reservation.Status)
                                </span>
                            </td>
                            <td class="px-gap-sm py-gap-sm">
                                <div class="flex items-center gap-gap-xs">
                                    @if (reservation.Status == "Pending")
                                    {
                                    <form asp-controller="Admin" asp-action="UpdateReservationStatus" method="post" class="inline">
                                        <input name="id" type="hidden" value="@reservation.Id" />
                                        <input name="status" type="hidden" value="Confirmed" />
                                        <button class="orion-button orion-button-primary text-caption px-3 py-1" type="submit" style="min-height:unset;">
                                            <span class="material-symbols-outlined text-sm">check</span>
                                            Onayla
                                        </button>
                                    </form>
                                    }
                                    <form asp-controller="Admin" asp-action="UpdateReservationStatus" method="post" class="flex items-center gap-gap-xs">
                                        <input name="id" type="hidden" value="@reservation.Id" />
                                        <select name="status" class="bg-surface-raised border border-border text-text-primary text-caption rounded px-2 py-1 focus:border-primary focus:outline-none" onchange="this.form.submit()">
                                            <option selected="@(reservation.Status == "Pending")" value="Pending">Beklemede</option>
                                            <option selected="@(reservation.Status == "Confirmed")" value="Confirmed">Onaylandı</option>
                                            <option selected="@(reservation.Status == "Completed")" value="Completed">Tamamlandı</option>
                                            <option selected="@(reservation.Status == "Cancelled")" value="Cancelled">İptal Edildi</option>
                                        </select>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
