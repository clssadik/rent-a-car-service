@model RentACarService.ViewModels.AdminCustomersViewModel

@{
    ViewData["Title"] = "Müşteri Yönetimi";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-gap-md mb-gap-lg">
        <div>
            <span class="text-primary font-bold uppercase tracking-wide text-caption">Müşteri Kayıtları</span>
            <h1 class="text-h1 font-bold text-text-primary mt-2">Müşteri Yönetimi</h1>
            <p class="text-text-secondary max-w-2xl">Tüm kayıtlı müşterileri ve rezervasyon geçmişlerini görüntüleyin.</p>
        </div>
        <a class="orion-button orion-button-primary" asp-controller="Admin" asp-action="Index">
            <span class="material-symbols-outlined">dashboard</span>
            Admin Paneli
        </a>
    </div>

    @if (!Model.Customers.Any())
    {
        <div class="orion-card p-gap-lg text-center">
            <span class="material-symbols-outlined text-5xl text-text-muted mb-gap-sm block">groups</span>
            <h2 class="text-h3 font-semibold mb-2">Henüz müşteri yok</h2>
            <p class="text-text-secondary max-w-prose mx-auto">Müşteriler rezervasyon oluşturdukça burada görünecektir. Yeni müşteri kayıtları rezervasyon işlemi sırasında otomatik oluşturulur.</p>
        </div>
    }
    else
    {
        <div class="orion-card overflow-hidden">
            <div class="p-gap-md border-b border-border flex justify-between items-center">
                <h2 class="text-h3 font-semibold">Tüm Müşteriler</h2>
                <span class="text-text-secondary text-caption">@Model.Customers.Count kayıt</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-surface-raised text-text-secondary text-caption uppercase">
                        <tr>
                            <th class="px-gap-sm py-gap-sm">ID</th>
                            <th class="px-gap-sm py-gap-sm">Ad Soyad</th>
                            <th class="px-gap-sm py-gap-sm">E-posta</th>
                            <th class="px-gap-sm py-gap-sm">Telefon Numarası</th>
                            <th class="px-gap-sm py-gap-sm">Rezervasyon Sayısı</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var customer in Model.Customers)
                        {
                            <tr class="hover:bg-surface-raised/60 transition-colors">
                                <td class="px-gap-sm py-gap-sm font-code text-text-muted">@customer.Id</td>
                                <td class="px-gap-sm py-gap-sm">@customer.FullName</td>
                                <td class="px-gap-sm py-gap-sm text-text-secondary">@customer.Email</td>
                                <td class="px-gap-sm py-gap-sm text-text-secondary">@customer.PhoneNumber</td>
                                <td class="px-gap-sm py-gap-sm">
                                    <span class="border border-border bg-surface-raised rounded px-2 py-1 text-caption">@customer.ReservationCount</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
