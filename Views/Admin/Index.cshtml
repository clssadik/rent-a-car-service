@model RentACarService.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="page-section">
    <div class="container">
        <div class="page-title-row">
            <div>
                <span class="section-label">Management</span>
                <h1>Admin Dashboard</h1>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="stat-card">
                    <span>Total Cars</span>
                    <strong>@Model.TotalCars</strong>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="stat-card">
                    <span>Active Reservations</span>
                    <strong>@Model.ActiveReservations</strong>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="stat-card">
                    <span>Customers</span>
                    <strong>@Model.Customers</strong>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="stat-card">
                    <span>Total Revenue</span>
                    <strong>$@Model.TotalRevenue.ToString("N0")</strong>
                </div>
            </div>
        </div>

        <div class="table-panel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Recent Reservations</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Customer name</th>
                            <th>Car</th>
                            <th>Pickup date</th>
                            <th>Return date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.RecentReservations)
                        {
                            <tr>
                                <td>@reservation.CustomerName</td>
                                <td>@reservation.CarName</td>
                                <td>@reservation.PickupDate.ToString("yyyy-MM-dd")</td>
                                <td>@reservation.ReturnDate.ToString("yyyy-MM-dd")</td>
                                <td><span class="badge text-bg-light border">@reservation.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
