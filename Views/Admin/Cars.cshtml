@model List<RentACarService.Models.Car>

@{
    ViewData["Title"] = "Car Management";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-gap-md mb-gap-lg">
        <div>
            <span class="text-primary font-bold uppercase tracking-wide text-caption">Fleet Setup</span>
            <h1 class="text-h1 font-bold text-text-primary mt-2">Car Management</h1>
            <p class="text-text-secondary max-w-2xl">Manage sample fleet data before the Entity Framework database layer is added.</p>
        </div>
        <button class="orion-button orion-button-primary" type="button">
            <span class="material-symbols-outlined">add</span>
            Add New Car
        </button>
    </div>

    <div class="orion-card overflow-hidden mb-gap-lg">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-raised text-text-secondary text-caption uppercase">
                    <tr>
                        <th class="px-gap-sm py-gap-sm">Image</th>
                        <th class="px-gap-sm py-gap-sm">Brand</th>
                        <th class="px-gap-sm py-gap-sm">Model</th>
                        <th class="px-gap-sm py-gap-sm">Year</th>
                        <th class="px-gap-sm py-gap-sm">Daily price</th>
                        <th class="px-gap-sm py-gap-sm">Availability</th>
                        <th class="px-gap-sm py-gap-sm">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var car in Model)
                    {
                        <tr class="hover:bg-surface-raised/60 transition-colors">
                            <td class="px-gap-sm py-gap-sm">
                                <div class="w-20 h-12 bg-surface-raised border border-border rounded flex items-center justify-center">
                                    <span class="material-symbols-outlined text-text-muted">directions_car</span>
                                </div>
                            </td>
                            <td class="px-gap-sm py-gap-sm">@car.Brand</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@car.Model</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@car.Year</td>
                            <td class="px-gap-sm py-gap-sm font-code text-primary">$@car.DailyPrice</td>
                            <td class="px-gap-sm py-gap-sm">
                                <span class="@(car.IsAvailable ? "bg-success text-bg-app" : "bg-text-muted text-bg-app") rounded px-2 py-1 text-caption font-bold">
                                    @(car.IsAvailable ? "Available" : "Unavailable")
                                </span>
                            </td>
                            <td class="px-gap-sm py-gap-sm">
                                <div class="flex gap-gap-xs">
                                    <button class="border border-border rounded px-3 py-2 text-caption hover:border-primary hover:text-primary transition-colors" type="button">Edit</button>
                                    <button class="border border-error text-error rounded px-3 py-2 text-caption hover:bg-error hover:text-white transition-colors" type="button">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="orion-card p-gap-md">
        <h2 class="text-h3 font-semibold mb-gap-sm">Add / Edit Car</h2>
        <form class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gap-sm">
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="brand">Brand</label>
                <input class="orion-input" id="brand" type="text" placeholder="Toyota" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="model">Model</label>
                <input class="orion-input" id="model" type="text" placeholder="Corolla" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="year">Year</label>
                <input class="orion-input" id="year" type="number" placeholder="2022" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="fuelType">Fuel type</label>
                <select class="orion-input" id="fuelType">
                    <option>Gasoline</option>
                    <option>Diesel</option>
                    <option>Hybrid</option>
                    <option>Electric</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="transmission">Transmission</label>
                <select class="orion-input" id="transmission">
                    <option>Automatic</option>
                    <option>Manual</option>
                </select>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="dailyPrice">Daily price</label>
                <input class="orion-input" id="dailyPrice" type="number" placeholder="45" />
            </div>
            <div class="lg:col-span-2">
                <label class="block text-caption text-text-secondary mb-2" for="imageUrl">Image URL</label>
                <input class="orion-input" id="imageUrl" type="url" placeholder="https://example.com/car.jpg" />
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" for="availability">Availability</label>
                <select class="orion-input" id="availability">
                    <option>Available</option>
                    <option>Unavailable</option>
                </select>
            </div>
            <div class="md:col-span-2 lg:col-span-3">
                <button class="orion-button orion-button-primary" type="submit">Save Car</button>
            </div>
        </form>
    </div>
</section>
