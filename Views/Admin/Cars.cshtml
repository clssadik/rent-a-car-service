@model RentACarService.ViewModels.AdminCarsViewModel

@{
    ViewData["Title"] = "Araç Yönetimi";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-gap-md mb-gap-lg">
        <div>
            <span class="text-primary font-bold uppercase tracking-wide text-caption">Filo Ayarları</span>
            <h1 class="text-h1 font-bold text-text-primary mt-2">Araç Yönetimi</h1>
            <p class="text-text-secondary max-w-2xl">Filo verilerini yönetin.</p>
        </div>
        <button class="orion-button orion-button-primary" type="button">
            <span class="material-symbols-outlined">add</span>
            Yeni Araç Ekle
        </button>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="mb-gap-md bg-success/10 border border-success text-success p-gap-sm rounded" role="alert">
            @successMessage
        </div>
    }

    <div class="orion-card overflow-hidden mb-gap-lg">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-raised text-text-secondary text-caption uppercase">
                    <tr>
                        <th class="px-gap-sm py-gap-sm">Görsel</th>
                        <th class="px-gap-sm py-gap-sm">Marka</th>
                        <th class="px-gap-sm py-gap-sm">Model</th>
                        <th class="px-gap-sm py-gap-sm">Yıl</th>
                        <th class="px-gap-sm py-gap-sm">Günlük fiyat</th>
                        <th class="px-gap-sm py-gap-sm">Müsaitlik</th>
                        <th class="px-gap-sm py-gap-sm">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var car in Model.Cars)
                    {
                        <tr class="hover:bg-surface-raised/60 transition-colors">
                            <td class="px-gap-sm py-gap-sm">
                                <div class="w-20 h-12 bg-surface-raised border border-border rounded flex items-center justify-center">
                                    <span class="material-symbols-outlined text-text-muted">directions_car</span>
                                </div>
                            </td>
                            <td class="px-gap-sm py-gap-sm">@car.Brand</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@car.Model</td>
                            <td class="px-gap-sm py-gap-sm text-text-secondary">@car.Year</td>
                            <td class="px-gap-sm py-gap-sm font-code text-primary">$@car.DailyPrice</td>
                            <td class="px-gap-sm py-gap-sm">
                                <span class="@(car.IsAvailable ? "bg-success text-bg-app" : "bg-text-muted text-bg-app") rounded px-2 py-1 text-caption font-bold">
                                    @(car.IsAvailable ? "Müsait" : "Müsait Değil")
                                </span>
                            </td>
                            <td class="px-gap-sm py-gap-sm">
                                <div class="flex gap-gap-xs">
                                    <a class="border border-border rounded px-3 py-2 text-caption hover:border-primary hover:text-primary transition-colors" asp-controller="Admin" asp-action="Cars" asp-route-editId="@car.Id">Düzenle</a>
                                    <form asp-controller="Admin" asp-action="DeleteCar" method="post">
                                        <input name="id" type="hidden" value="@car.Id" />
                                        <button class="border border-error text-error rounded px-3 py-2 text-caption hover:bg-error hover:text-white transition-colors" type="submit" onclick="return confirm('Bu aracı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.')">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="orion-card p-gap-md">
        <h2 class="text-h3 font-semibold mb-gap-sm">Araç Ekle / Düzenle</h2>
        <form class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gap-sm" asp-controller="Admin" asp-action="Cars" method="post">
            <input asp-for="Form.Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-error md:col-span-2 lg:col-span-3"></div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.Brand">Marka</label>
                <input class="orion-input" asp-for="Form.Brand" placeholder="Toyota" />
                <span class="text-error text-caption" asp-validation-for="Form.Brand"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.Model">Model</label>
                <input class="orion-input" asp-for="Form.Model" placeholder="Corolla" />
                <span class="text-error text-caption" asp-validation-for="Form.Model"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.Year">Yıl</label>
                <input class="orion-input" asp-for="Form.Year" placeholder="2022" />
                <span class="text-error text-caption" asp-validation-for="Form.Year"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.FuelType">Yakıt tipi</label>
                <select class="orion-input" asp-for="Form.FuelType">
                    <option>Benzin</option>
                    <option>Dizel</option>
                    <option>Hibrit</option>
                    <option>Elektrik</option>
                </select>
                <span class="text-error text-caption" asp-validation-for="Form.FuelType"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.Transmission">Vites</label>
                <select class="orion-input" asp-for="Form.Transmission">
                    <option>Otomatik</option>
                    <option>Manuel</option>
                </select>
                <span class="text-error text-caption" asp-validation-for="Form.Transmission"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.Type">Araç tipi</label>
                <select class="orion-input" asp-for="Form.Type">
                    <option>Sedan</option>
                    <option>SUV</option>
                    <option>Hatchback</option>
                    <option>Van</option>
                </select>
                <span class="text-error text-caption" asp-validation-for="Form.Type"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.SeatCount">Koltuk sayısı</label>
                <input class="orion-input" asp-for="Form.SeatCount" placeholder="5" />
                <span class="text-error text-caption" asp-validation-for="Form.SeatCount"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.DailyPrice">Günlük fiyat</label>
                <input class="orion-input" asp-for="Form.DailyPrice" placeholder="45" />
                <span class="text-error text-caption" asp-validation-for="Form.DailyPrice"></span>
            </div>
            <div class="lg:col-span-2">
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.ImageUrl">Görsel URL</label>
                <input class="orion-input" asp-for="Form.ImageUrl" placeholder="https://example.com/car.jpg" />
                <span class="text-error text-caption" asp-validation-for="Form.ImageUrl"></span>
            </div>
            <div>
                <label class="block text-caption text-text-secondary mb-2" asp-for="Form.IsAvailable">Müsaitlik</label>
                <select class="orion-input" asp-for="Form.IsAvailable">
                    <option value="true">Müsait</option>
                    <option value="false">Müsait Değil</option>
                </select>
            </div>
            <div class="md:col-span-2 lg:col-span-3">
                <button class="orion-button orion-button-primary" type="submit">Aracı Kaydet</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
