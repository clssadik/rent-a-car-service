    var carImages = new[]
    {
        "https://lh3.googleusercontent.com/aida-public/AB6AXuAmzmVcS_8aKFQjfV_6DpwpltRXSI5C16aWteXTXEodxMabdSm4zSwP5fD1HbRKS2PyYkSUS1ZHcfZ2ynFMfDLleaOE9XtMMRuT9DX8fOWqZBHR1rndErP_t5TwEwX1Zi1QWoK7qegi-BfLCsT1CJohikinqlVziqZdlhKRscqQLjzDZRf4uNT4ywLSXhPxapyN2JoJSP1N_UzaGLfjyLSf9EK8oHdl5uCwBLrhWmCwwxBofUi1l8FSQMcEpxVS-WPVYRS5meXfIOU",
        "https://lh3.googleusercontent.com/aida-public/AB6AXuB-p8cQtb7f3i4gOI-S1bRvYY32xOkTjVBfgW0UXSjLqsPgF8tSnrYSZT_VXLdm1LQD7eYOOeNavuP5TKOHaJsQ5SfUUhgnou13HjNw0SD83EMiAeiTYOgcb7qPmhDq5zaOsBKRd2zeWxicvsJWkMXoFhXl6CkFYcvUcDhMB2qIq-cbo4aRDk86S3YStVlPNc6Tx_WPhv_LebPHz7hGOUeyZAxWhpZmM5czG5R24L-CzyGJTRP1A5FZE_GBUfQqyZKm3OmIzYARQa8",
        "https://lh3.googleusercontent.com/aida-public/AB6AXuD6MF7Ul26V5gy0NttjKlw_R_EofYlyDu3TYoT7yp6nMjj5Cw0uFSvGbnW-FSEpCdgSIcjGoZ2dpqGnR07eGSzNu6VJqz4ogf0hWIk8UhbhUW4hWkDINxNaNNMTRU5hdxSrwuj6vS_KGpfhLDBch3xqhLwFzLWJK2TK-DZd66s-r0eXAlouAc4v3vTLUCB9lEyTH7jRJTBdmEEXZVLUt-2z7RAEoWhi96dX6fqfD07smb9Qotjjt5QcrIghCmwAah5WEohwcMaN83o"
    };
}

<section class="w-full relative py-section-lg flex flex-col items-center justify-center min-h-[716px] hero-pattern px-gutter overflow-hidden">
    <div class="max-w-container-max w-full mx-auto relative z-10 text-center flex flex-col items-center gap-gap-md">
        <h1 class="font-display text-display text-text-primary max-w-4xl text-center">Find your perfect car with MEU RENT</h1>
        <p class="text-body text-text-secondary max-w-2xl text-center">Experience precision engineering and seamless performance. Fast booking, zero friction.</p>

        <form class="mt-gap-lg bg-surface border border-border rounded-lg shadow-[0_4px_20px_rgba(0,0,0,0.6)] p-gap-sm w-full max-w-5xl flex flex-col md:flex-row gap-gap-sm items-center" asp-controller="Cars" asp-action="Index" method="get">
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">location_on</span>
                <input class="orion-input pl-10" name="location" placeholder="Pick-up location" type="text" />
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">calendar_today</span>
                <input class="orion-input pl-10" name="pickupDate" type="date" />
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">calendar_month</span>
                <input class="orion-input pl-10" name="returnDate" type="date" />
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">directions_car</span>
                <select class="orion-input pl-10 appearance-none cursor-pointer" name="carType">
                    <option value="">Car type</option>
                    <option value="Sedan">Sedan</option>
                    <option value="SUV">SUV</option>
                    <option value="Hatchback">Hatchback</option>
                    <option value="Van">Van</option>
                </select>
            </div>
            <button class="orion-button orion-button-primary w-full md:w-auto flex-shrink-0" type="submit">
                <span class="material-symbols-outlined">search</span>
                Search
            </button>
        </form>
    </div>
    <div class="absolute inset-0 z-0 opacity-20 bg-cover bg-center" style="background-image: url('@heroImage');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg-app via-transparent to-transparent z-0"></div>
</section>

<section class="w-full max-w-container-max mx-auto px-gutter py-section-lg flex flex-col gap-gap-lg">
    <div class="flex flex-col sm:flex-row justify-between gap-gap-md sm:items-end">
        <h2 class="text-h1 text-text-primary font-bold">Featured Fleet</h2>
        <a class="text-body text-primary hover:text-orange-light flex items-center gap-1 transition-colors" asp-controller="Cars" asp-action="Index">
            View all <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gap-md">
        @for (var i = 0; i < Model.Count; i++)
        {
            var car = Model[i];
            var image = carImages[i % carImages.Length];
            <article class="orion-card overflow-hidden flex flex-col group hover:border-primary transition-colors">
                <div class="h-48 bg-surface-raised relative overflow-hidden">
                    <img alt="@car.Brand @car.Model" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@image" />
                    <div class="absolute top-3 right-3 bg-primary text-white text-caption px-2 py-1 rounded font-bold">FEATURED</div>
                </div>
                <div class="p-gap-sm flex flex-col gap-gap-xs flex-grow">
                    <div class="flex justify-between items-start gap-gap-sm">
                        <h3 class="text-h3 text-text-primary font-semibold">@car.Brand @car.Model</h3>
                        <span class="font-code text-primary font-bold whitespace-nowrap">$@car.DailyPrice/d</span>
                    </div>
                    <p class="text-text-secondary text-sm">@car.Type</p>
                    <div class="grid grid-cols-2 gap-2 mt-4 text-caption text-text-muted">
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">airline_seat_recline_normal</span> 5 Seats</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">settings</span> Auto</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">speed</span> Ready</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">local_gas_station</span> Fuel</div>
                    </div>
                </div>
                <div class="p-gap-sm pt-0">
                    <a class="orion-button orion-button-outline w-full" asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">Reserve</a>
                </div>
            </article>
        }
    </div>
</section>

<section class="w-full border-t border-border bg-surface/40">
    <div class="max-w-container-max mx-auto px-gutter py-section-md grid grid-cols-1 md:grid-cols-3 gap-gap-md">
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">payments</span>
            <h3 class="text-h3 font-semibold mb-2">Affordable Prices</h3>
            <p class="text-text-secondary">Transparent daily prices and simple rental summaries.</p>
        </div>
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">event_available</span>
            <h3 class="text-h3 font-semibold mb-2">Easy Reservation</h3>
            <p class="text-text-secondary">Choose a car and complete a reservation form in minutes.</p>
        </div>
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">verified</span>
            <h3 class="text-h3 font-semibold mb-2">Reliable Vehicles</h3>
            <p class="text-text-secondary">Organized vehicle details help customers rent with confidence.</p>
        </div>
    </div>
</section>
