@model List<RentACarService.Models.Car>
@using System.IO
@{
    ViewData["Title"] = "Ana Sayfa";
    var heroImage = "/images/hero-bg.jpg";
    string GetCarImage(RentACarService.Models.Car car)
    {
        var prefix = $"{car.Brand}-{car.Model}".ToLower().Replace(" ", "-");
        var dir = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "cars", prefix);
        if (System.IO.Directory.Exists(dir))
        {
            var first = System.IO.Directory.GetFiles(dir, "*").Select(System.IO.Path.GetFileName).OrderBy(f => f).FirstOrDefault();
            if (first != null) return $"/images/cars/{prefix}/{first}";
        }
        return "/images/cars/porsche-911-turbo-s/porsche-911-turbo-s-1.jpg";
    }
}

<section class="w-full relative -mt-16 py-section-lg flex flex-col items-center justify-center min-h-[716px] hero-pattern px-gutter">
    <div class="max-w-5xl w-full mx-açuto relative z-10 text-left flex flex-col items-start gap-gap-md pt-20">
        <h1 class="font-serif text-[80px] leading-none text-text-primary">
            Hayalinizdeki<br />
            <span class="font-serif">Yolculuk</span>
        </h1>

        <form class="orion-search-form glass mt-[200px] rounded-lg shadow-[0_4px_20px_rgba(0,0,0,0.6)] p-gap-sm w-full max-w-5xl flex flex-col md:flex-row gap-gap-sm items-center" asp-controller="Cars" asp-action="Index" method="get">
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white z-10">location_on</span>
                <input class="orion-input pl-10" id="locationInput" name="location" placeholder="Alış lokasyonu" type="text" autocomplete="off" onfocus="showProvinceDropdown()" oninput="filterProvinces()" onblur="setTimeout(()=>hideProvinceDropdown(),200)" />
                <div id="provinceDropdown" class="absolute top-full left-0 right-0 mt-1 orion-card p-gap-xs hidden flex-col max-h-48 overflow-y-auto z-50" style="display:none"></div>
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white">calendar_today</span>
                <input class="orion-input pl-10" name="pickupDate" placeholder="Alış tarihi" type="text" onfocus="this.type='date'; this.showPicker?.()" onblur="if (!this.value) this.type='text'" />
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white">calendar_month</span>
                <input class="orion-input pl-10" name="returnDate" placeholder="İade tarihi" type="text" onfocus="this.type='date'; this.showPicker?.()" onblur="if (!this.value) this.type='text'" />
            </div>
            <div class="flex-1 w-full relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white">directions_car</span>
                <select class="orion-input pl-10 appearance-none cursor-pointer" name="carType">
                    <option value="">Araç tipi</option>
                    <option value="Sedan">Sedan</option>
                    <option value="SUV">SUV</option>
                    <option value="Hatchback">Hatchback</option>
                    <option value="Van">Van</option>
                </select>
            </div>
            <button class="orion-button orion-button-primary w-full md:w-auto flex-shrink-0" type="submit">
                <span class="material-symbols-outlined">search</span>
                    Ara
            </button>
        </form>
    </div>
    <div class="absolute inset-0 z-0 opacity-100 bg-cover bg-center" style="background-image: url('@heroImage');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg-app via-transparent to-transparent z-0"></div>
</section>

<section class="w-full max-w-container-max mx-auto px-gutter py-section-lg flex flex-col gap-gap-lg">
    <div class="flex flex-col sm:flex-row justify-between gap-gap-md sm:items-end">
        <h2 class="text-h1 text-text-primary font-bold">Öne Çıkan Araçlarlarımız</h2>
        <a class="text-body text-primary hover:text-orange-light flex items-center gap-1 transition-colors" asp-controller="Cars" asp-action="Index">
            Tümünü gör <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gap-md">
        @for (var i = 0; i < Model.Count; i++)
        {
            var car = Model[i];
            <article class="orion-card overflow-hidden flex flex-col group hover:border-primary transition-colors">
                <div class="h-48 bg-surface-raised relative overflow-hidden">
                    <img alt="@car.Brand @car.Model" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@GetCarImage(car)" />
                    <div class="absolute top-3 right-3 bg-primary text-bg-app text-caption px-2 py-1 rounded font-bold">ÖNE ÇIKAN</div>
                </div>
                <div class="p-gap-sm flex flex-col gap-gap-xs flex-grow">
                    <div class="flex justify-between items-start gap-gap-sm">
                        <h3 class="text-h3 text-text-primary font-semibold">@car.Brand @car.Model</h3>
                        <span class="font-code text-primary font-bold whitespace-nowrap">₺@car.DailyPrice.ToString("N0")/g</span>
                    </div>
                    <p class="text-text-secondary text-sm">@car.Type</p>
                    <div class="grid grid-cols-2 gap-2 mt-4 text-caption text-text-muted">
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">airline_seat_recline_normal</span> @car.SeatCount Koltuk</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">settings</span> @(car.Transmission == "Automatic" ? "Otomatik" : "Manuel")</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">speed</span> @(car.IsAvailable ? "Hazır" : "Rezerve")</div>
                        <div class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">local_gas_station</span> @car.FuelType</div>
                    </div>
                </div>
                <div class="p-gap-sm pt-0">
                    <a class="orion-button orion-button-primary w-full" asp-controller="Cars" asp-action="Review" asp-route-id="@car.Id">İncele</a>
                </div>
            </article>
        }
    </div>
</section>

<section class="w-full border-t border-border bg-surface/40">
    <div class="max-w-container-max mx-auto px-gutter py-section-md grid grid-cols-1 md:grid-cols-3 gap-gap-md">
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">payments</span>
            <h3 class="text-h3 font-semibold mb-2">Uygun Fiyatlar</h3>
            <p class="text-text-secondary">Şeffaf günlük fiyatlar ve basit kiralama özetleri.</p>
        </div>
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">event_available</span>
            <h3 class="text-h3 font-semibold mb-2">Kolay Rezervasyon</h3>
            <p class="text-text-secondary">Dakikalar içinde araç seçin ve rezervasyon formunu doldurun.</p>
        </div>
        <div class="orion-card p-gap-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-gap-sm">verified</span>
            <h3 class="text-h3 font-semibold mb-2">Güvenilir Araçlar</h3>
            <p class="text-text-secondary">Düzenli araç bilgileri müşterilerin güvenle kiralamasını sağlar.</p>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        var provinces = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((List<RentACarService.Models.Province>)ViewBag.Provinces).Select(p => p.Name)));
        var dropdown = document.getElementById('provinceDropdown');
        var input = document.getElementById('locationInput');

        function showProvinceDropdown() {
            filterProvinces();
        }

        function hideProvinceDropdown() {
            dropdown.style.display = 'none';
        }

        function filterProvinces() {
            var q = input.value.toLowerCase();
            var matches = provinces.filter(function(p) { return p.toLowerCase().includes(q); }).slice(0, 5);
            if (matches.length === 0 || (matches.length === 1 && matches[0].toLowerCase() === q.toLowerCase())) {
                dropdown.style.display = 'none';
                return;
            }
            dropdown.innerHTML = matches.map(function(p) {
                return '<div class="px-2 py-1 rounded hover:bg-surface-raised cursor-pointer text-text-primary text-caption" onmousedown="selectProvince(\'' + p + '\')">' + p + '</div>';
            }).join('');
            dropdown.style.display = 'flex';
        }

        function selectProvince(name) {
            input.value = name;
            dropdown.style.display = 'none';
        }
    </script>
}
