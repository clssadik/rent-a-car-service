@{
    ViewData["Title"] = "Hakkımızda";
}

<section class="max-w-container-max mx-auto px-gutter py-section-md">
    <div class="mb-gap-lg">
        <span class="text-white font-bold uppercase tracking-wide text-body">Hakkımızda</span>
        <h1 class="text-h1 font-bold text-text-primary mt-2">Mersin Üniversitesi Bilgisayar Mühendisliği</h1>
        <p class="text-text-secondary mt-gap-sm">Mersin Üniversitesi Mühendislik Fakültesi bünyesinde yer alan Bilgisayar Mühendisliği Bölümü, çağdaş eğitim anlayışı ve güçlü akademik kadrosuyla geleceğin mühendislerini yetiştirmektedir.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gap-md mb-gap-lg">
        <div class="orion-card p-gap-md flex flex-col">
            <span class="material-symbols-outlined text-white text-4xl mb-gap-sm">school</span>
            <h3 class="text-h3 font-semibold mb-2">Lisans Programı</h3>
            <p class="text-text-secondary flex-1">4 yıllık Bilgisayar Mühendisliği lisans programı, teorik ve uygulamalı derslerle öğrencileri sektöre hazırlar. Program dili Türkçe'dir.</p>
        </div>
        <div class="orion-card p-gap-md flex flex-col">
            <span class="material-symbols-outlined text-white text-4xl mb-gap-sm">science</span>
            <h3 class="text-h3 font-semibold mb-2">Lisansüstü Eğitim</h3>
            <p class="text-text-secondary flex-1">Yüksek Lisans ve Doktora programları ile araştırma odaklı akademik kariyer imkanı sunar. Tezli ve tezsiz yüksek lisans seçenekleri mevcuttur.</p>
        </div>
        <div class="orion-card p-gap-md flex flex-col">
            <span class="material-symbols-outlined text-white text-4xl mb-gap-sm">biotech</span>
            <h3 class="text-h3 font-semibold mb-2">Araştırma Alanları</h3>
            <p class="text-text-secondary flex-1">Yapay zeka, makine öğrenmesi, bilgisayar ağları, veri tabanı sistemleri, yazılım mühendisliği, gömülü sistemler ve siber güvenlik alanlarında araştırmalar yürütülmektedir.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-gap-lg mb-gap-lg">
        <div class="orion-card p-gap-md">
            <h2 class="text-h3 font-semibold mb-gap-sm">Akademik Kadro</h2>
            <p class="text-text-secondary">Bölümümüzde alanında uzman profesör, doçent, doktor öğretim üyesi ve araştırma görevlilerinden oluşan güçlü bir akademik kadro görev yapmaktadır. Öğretim üyelerimiz ulusal ve uluslararası projelerde aktif rol almaktadır.</p>
        </div>
        <div class="orion-card p-gap-md">
            <h2 class="text-h3 font-semibold mb-gap-sm">Laboratuvarlar</h2>
            <p class="text-text-secondary">Bölümümüzde öğrencilerin uygulamalı eğitim alabileceği modern bilgisayar laboratuvarları, ağ ve siber güvenlik laboratuvarı, gömülü sistemler laboratuvarı ve yapay zeka araştırma laboratuvarı bulunmaktadır.</p>
        </div>
    </div>

    <div class="orion-card p-gap-md mb-gap-lg">
        <h2 class="text-h3 font-semibold mb-gap-sm">Ders Programı</h2>
        <p class="text-text-secondary mb-gap-md">Lisans programı boyunca öğrencilerimiz şu temel alanlarda eğitim almaktadır:</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-gap-sm">
            <div class="bg-surface-raised p-gap-sm rounded flex flex-col">
                <span class="material-symbols-outlined text-white mb-2">code</span>
                <h3 class="font-semibold text-text-primary mb-1">Yazılım</h3>
                <p class="text-caption text-text-secondary flex-1">Programlama dilleri, veri yapıları, algoritmalar, yazılım mühendisliği, web ve mobil uygulama geliştirme</p>
            </div>
            <div class="bg-surface-raised p-gap-sm rounded flex flex-col">
                <span class="material-symbols-outlined text-white mb-2">memory</span>
                <h3 class="font-semibold text-text-primary mb-1">Donanım ve Sistemler</h3>
                <p class="text-caption text-text-secondary flex-1">Bilgisayar mimarisi, işletim sistemleri, gömülü sistemler, sayısal tasarım, mikroişlemciler</p>
            </div>
            <div class="bg-surface-raised p-gap-sm rounded flex flex-col">
                <span class="material-symbols-outlined text-white mb-2">hub</span>
                <h3 class="font-semibold text-text-primary mb-1">Ağ ve Veri</h3>
                <p class="text-caption text-text-secondary flex-1">Bilgisayar ağları, veri tabanı yönetimi, bilgi güvenliği, yapay zeka, makine öğrenmesi</p>
            </div>
        </div>
    </div>

    <div class="orion-card p-gap-md">
        <h2 class="text-h3 font-semibold mb-gap-sm">İletişim</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-gap-sm text-text-secondary">
            <div>
                <p class="text-caption text-text-muted">Adres</p>
                <p>Mersin Üniversitesi Mühendislik Fakültesi, Çiftlikköy Kampüsü, 33343 Yenişehir / Mersin</p>
            </div>
            <div>
                <p class="text-caption text-text-muted">Web</p>
                <a class="text-white hover:text-primary transition-colors" href="https://www.mersin.edu.tr" target="_blank">mersin.edu.tr</a>
            </div>
        </div>
    </div>
</section>
